# Project-local overrides (optional)
# Copy to .env in this folder. Global API keys live in the repo root .env.
#
# Load order:
#   1. <repo-root>/.env
#   2. 02. Fast API Application/.env  (overrides global)

# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_RETRIES=3
APP_TITLE=OpenAI Chat API
APP_DEBUG=true
